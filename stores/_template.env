# Duplicate had fichier l kol store jdid f EasyPanel
APP_ENV=production
APP_NAME=CHANGE_ME Store Backend
API_BASE_URL=https://$(PRIMARY_DOMAIN)
FRONTEND_URL=https://CHANGE_ME_STORE_DOMAIN
CORS_ORIGINS=https://CHANGE_ME_STORE_DOMAIN,https://www.CHANGE_ME_STORE_DOMAIN
DATABASE_URL=postgres://postgres:CHANGE_ME@$(PROJECT_NAME)_postgres:5432/$(PROJECT_NAME)
GOOGLE_SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_API_VERSION=v1.3
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=
ENABLE_CAPI=true
ENABLE_META_CAPI=true
ENABLE_TIKTOK_CAPI=true
ENABLE_SNAP_CAPI=true
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
ENABLE_IP_FRAUD-CHECK=true
WHITELISTED_PHONES=+96550000000,050000000
LOG_LEVEL=INFO
