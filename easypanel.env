# =============================================================================
# EasyPanel → project: larabeauty → service: backend → Environment
# Copy-paste kolchi lta7t. Secrets (META_ACCESS_TOKEN, etc.) — chof docs/SECRETS.md
# Port service: 3000 | Build: Dockerfile | Branch: main
# =============================================================================

APP_ENV=production
APP_NAME=Lara Beauty GCC Backend
API_BASE_URL=https://$(PRIMARY_DOMAIN)
FRONTEND_URL=https://lara-beauty.com
CORS_ORIGINS=https://lara-beauty.com,https://www.lara-beauty.com

# PostgreSQL f nfs project (service smito postgres). Password mn EasyPanel → postgres → Credentials
DATABASE_URL=postgres://postgres:CHANGE_ME_POSTGRES_PASSWORD@$(PROJECT_NAME)_postgres:5432/$(PROJECT_NAME)

# Google Apps Script — Web App URL (Deploy → Anyone)
GOOGLE_SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# Meta Events Manager → Settings → Conversions API
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0

# TikTok Ads → Events → Web Events → Pixel
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_API_VERSION=v1.3

# Snapchat Ads → Events Manager
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=

ENABLE_CAPI=true
ENABLE_META_CAPI=true
ENABLE_TIKTOK_CAPI=true
ENABLE_SNAP_CAPI=true

# MaxMind minFraud → Account → Manage license keys
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
ENABLE_IP_FRAUD-CHECK=true

WHITELISTED_PHONES=+96550000000,050000000

LOG_LEVEL=INFO
