# =============================================================================
# COPY-PASTE → EasyPanel → Project → App (laragccbackend) → Environment
# Replace CHANGE_ME and your-domain.com before Deploy
# MySQL: create service named "mysql" in same project first
# =============================================================================

# Nixpacks (required for Laravel on EasyPanel)
NIXPACKS_PHP_ROOT_DIR=/app/public
NIXPACKS_PHP_FALLBACK_PATH=/index.php

# App
APP_NAME=Lara GCC Store
APP_ENV=production
APP_KEY=CHANGE_ME_run_php_artisan_key_generate_show
APP_DEBUG=false
APP_TIMEZONE=Asia/Dubai
APP_URL=https://$(PRIMARY_DOMAIN)

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

FRONTEND_URL=https://CHANGE_ME_store_frontend_domain

LOG_CHANNEL=stack
LOG_LEVEL=error

# Database — password from EasyPanel MySQL service page
DB_CONNECTION=mysql
DB_HOST=$(PROJECT_NAME)_mysql
DB_PORT=3306
DB_DATABASE=$(PROJECT_NAME)
DB_USERNAME=mysql
DB_PASSWORD=CHANGE_ME_mysql_password_from_easypanel

# Redis (only if you added a Redis service named "redis")
CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
# REDIS_HOST=$(PROJECT_NAME)_redis
# REDIS_PASSWORD=CHANGE_ME
# REDIS_PORT=6379
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@$(PRIMARY_DOMAIN)
MAIL_FROM_NAME=Lara GCC Store

FILESYSTEM_DISK=local

SANCTUM_STATEFUL_DOMAINS=$(PRIMARY_DOMAIN),CHANGE_ME_store_frontend_domain

# Run once after deploy (EasyPanel → App → Console / Launcher):
# php artisan key:generate --force
# php artisan migrate --force
# php artisan storage:link
# php artisan config:cache
