# App
APP_ENV=production
APP_NAME=Lara Beauty GCC Backend
PORT=3000
API_BASE_URL=https://api.your-domain.com
FRONTEND_URL=https://your-store.com
CORS_ORIGINS=https://your-store.com

# Database (PostgreSQL — optional event log)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Google Sheets (Apps Script web app URL)
GOOGLE_SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# Meta Conversion API
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
ENABLE_CAPI=true
ENABLE_META_CAPI=true

# TikTok Events API
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_API_VERSION=v1.3
ENABLE_TIKTOK_CAPI=true

# Snapchat CAPI
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=
ENABLE_SNAP_CAPI=true

# MaxMind fraud (use ENABLE_IP_FRAUD_CHECK or ENABLE_IP_FRAUD-CHECK on EasyPanel)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
ENABLE_IP_FRAUD_CHECK=true
WHITELISTED_PHONES=+96550000000,050000000

LOG_LEVEL=INFO
GIT_SHA=
